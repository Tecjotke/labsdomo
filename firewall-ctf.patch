+
+  /* ─── Hero ─── */
+  .hero { padding: 80px 0 100px; position: relative; }
+  .hero-grid {
+    display: grid;
+    grid-template-columns: 1.15fr 1fr;
+    gap: 64px;
+    align-items: center;
